<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>About Us — Legacy Home &amp; Respite Care Foundation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="styles.css">
</head>
<body>

<div class="demo-banner"><strong>DEMO PREVIEW</strong> · sample data only · built by X-Centric as a working preview for Legacy Home &amp; Respite Care Foundation</div>

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="index.html">
      <div class="brand-mark">L</div>
      <div class="brand-name">Legacy<small>Home &amp; Respite Care Foundation</small></div>
    </a>
    <button class="nav-toggle" aria-label="Menu" onclick="document.querySelector('.main-nav').classList.toggle('open')">☰</button>
    <nav class="main-nav">
      <a href="index.html">Home</a>
      <a href="about.html" class="active">About</a>
      <a href="programs.html">The Sanctuary</a>
      <a href="resources.html">Resource Hub</a>
      <a href="events.html">Events</a>
      <a href="portal.html" class="nav-portal">Caregiver Portal</a>
      <a href="index.html#donate" class="nav-cta">Donate</a>
    </nav>
  </div>
</header>

<section class="hero" style="padding: 56px 0 64px;">
  <div class="container">
    <h1 style="font-size: clamp(30px, 4vw, 44px);">{{ sections["about.hero"].title }}</h1>
    <p class="lede">{{ sections["about.hero"].lede }}</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="split">
      <div>
        <span class="eyebrow">{{ sections["about.story"].eyebrow }}</span>
        <h2 style="margin-bottom: 14px;">{{ sections["about.story"].heading }}</h2>
{%- for p in sections["about.story"].paragraphs %}
        <p class="muted mb-16">{{ p }}</p>
{%- endfor %}
        <p class="small muted"><em>{{ sections["about.story"].note }}</em></p>
      </div>
      <div class="visual">
        <h3 style="font-size: 18px; margin-bottom: 14px;">{{ sections["about.values"].heading }}</h3>
{%- for it in sections["about.values"]["items"] %}
        <div class="timeline-item"><div class="timeline-dot" style="background: var(--coral);"></div><div><strong>{{ it.title }}</strong><div class="when">{{ it.when }}</div></div></div>
{%- endfor %}
      </div>
    </div>
  </div>
</section>

<section style="background: var(--sand);">
  <div class="container text-center">
    <span class="eyebrow">{{ sections["about.join"].eyebrow }}</span>
    <h2 style="margin-bottom: 14px;">{{ sections["about.join"].heading }}</h2>
    <p class="muted" style="max-width: 540px; margin: 0 auto 28px;">{{ sections["about.join"].body }}</p>
    <a href="programs.html" class="btn btn-coral">{{ sections["about.join"].cta_label }}</a>
  </div>
</section>

{% include '_footer.html.j2' %}

<script src="app.js"></script>
</body>
</html>
